# ─── JWT ───────────────────────────────────────────────
# Any random long string. Used by ALL services to sign/verify tokens locally.
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Google OAuth (Auth Service only) ──────────────────
# Get from https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client
# Callback URL to register: http://localhost:4001/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── MySQL ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── MongoDB ────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/notif_db

# ─── RabbitMQ (used in Part 2) ──────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ─── Email / Nodemailer (used in Part 2) ────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── Service URLs (for inter-service HTTP calls) ─────────
AUTH_SERVICE_URL=http://auth-service:4001
RESULT_SERVICE_URL=http://result-service:4002
ADMIN_SERVICE_URL=http://admin-service:4003
